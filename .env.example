APP_NAME=Mental Interview Demo
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8090
CURRENT_STAGE=qa
QA_TEXT_ENABLED=true
QA_AUDIO_TRANSCRIPTION_ENABLED=true
ALLOW_LOCAL_AUDIO_PATH_INPUT=true
MOVIE_USES_TEXT_MODALITY=false
READING_USES_TEXT_MODALITY=false

LLM_PROVIDER=zhipu
ZHIPUAI_API_KEY=
ZHIPU_MODEL=glm-4-flash
ZHIPU_TIMEOUT_SECONDS=180
ZHIPU_MAX_RETRIES_429=3
ZHIPU_RETRY_BASE_DELAY_SECONDS=6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

TEXT_MODEL_PROVIDER=llm
AUDIO_MODEL_PROVIDER=local
VISION_MODEL_PROVIDER=local
MULTIMODAL_MODEL_PROVIDER=local
LOCAL_MODEL_ROOT=models
MODEL_DEVICE=cpu

TRANSCRIPTION_ENABLED=true
TRANSCRIPTION_PRIMARY=whisper
TRANSCRIPTION_FALLBACK=baidu
ENABLE_BAIDU_FALLBACK=true
TRANSCRIPTION_LANGUAGE=zh
WHISPER_MODEL_NAME=base
WHISPER_DEVICE=cpu
BAIDU_ASR_APP_ID=
BAIDU_ASR_API_KEY=
BAIDU_ASR_SECRET_KEY=
BAIDU_ASR_TIMEOUT_SECONDS=30
FFMPEG_BINARY=ffmpeg
FFMPEG_TIMEOUT_SECONDS=120
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
INTERVIEW_QUESTION_DIR=app/static/interview-assets/interview
INTERVIEW_ARCHIVE_ROOT=.cache/interviews
INTERVIEW_ANALYSIS_WORKERS=1
INTERVIEW_LOG_DIR=.cache/logs
TEMP_CLEANUP_MAX_AGE_SECONDS=300
KEEP_TEMP_FILES=false
